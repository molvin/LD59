{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "75e0eb05bdf9465185c0342df8ba4fa2",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "IDK (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -481.0,
            "y": 200.0,
            "width": 174.0,
            "height": 118.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "54e1d89c6d3842f2ae61651b74aa4c13"
        },
        {
            "m_Id": "349d1fb56f3a4e3c947a9b352b2d8bf0"
        },
        {
            "m_Id": "b5da4536bf2445f8ac4f01e0cc5458c2"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "IDK",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Access global buffers\r\nfloat4 control = SAMPLE_TEXTURE2D(_Control, sampler_Control, UV);\r\n\r\n// Apply the same tiling to all layers\r\nfloat2 tiledUV = UV * Tiling;\r\n\r\nfloat4 s0 = SAMPLE_TEXTURE2D(_Splat0, sampler_Splat0, tiledUV);\r\nfloat4 s1 = SAMPLE_TEXTURE2D(_Splat1, sampler_Splat1, tiledUV);\r\nfloat4 s2 = SAMPLE_TEXTURE2D(_Splat2, sampler_Splat2, tiledUV);\r\nfloat4 s3 = SAMPLE_TEXTURE2D(_Splat3, sampler_Splat3, tiledUV);\r\n\r\n// Blend using the weighted sum\r\nfloat4 finalColor = (s0 * control.r) + (s1 * control.g) + (s2 * control.b) + (s3 * control.a);\r\n\r\nOut = finalColor;"
}

